# MDT optional environment overrides (copy to .env if your tooling loads it)
# Most tunables live in config.py — edit that file for persistent changes.

# SERVER_HOST=127.0.0.1
# SERVER_PORT=8000
# MAX_DEVICES=2
# EMULATOR_MEMORY_MB=1536
# SCREENRECORD_SIZE=540x1170
# SCREENRECORD_BITRATE=2000000
# BOOT_STAGGER_SEC=8

# Android SDK (optional — MDT auto-detects if unset)
# Priority: .sdk_path.txt > MDT_ANDROID_SDK > ANDROID_SDK_ROOT > ANDROID_HOME >
#           OS default (~/Android/Sdk, ~/Library/Android/sdk, %LOCALAPPDATA%\Android\Sdk) >
#           project .android-sdk/
# MDT_ANDROID_SDK=/path/to/Android/Sdk
# ANDROID_SDK_ROOT=/path/to/Android/Sdk
# ANDROID_HOME=/path/to/Android/Sdk
